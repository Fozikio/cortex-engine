{
  "enabled": true,
  "strength": "block",
  "description": "Production push gate. Copy to .claude/state/project-boards.json and customize.",
  "on_push": {
    "require_board_update": true,
    "require_ops_log": false,
    "require_ops_log_message": "Log what you're pushing and why via ops_append() before pushing."
  },
  "repos": {
    "my-repo": {
      "board_number": 1,
      "board_owner": "my-org",
      "description": "Main application"
    }
  }
}
